# Copy this file to `.env` and adjust as needed.
# The defaults run the whole pipeline with a stub LLM (no Ollama needed).

# Set to false once `ollama serve` is running and your model is pulled.
USE_STUB_LLM=true

# Ollama connection + models.
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.4

# Path to your folder of past solved LeetCode solutions (retrieval source).
# Leave as-is to use the bundled ./leetcode folder.
# LEETCODE_DIR=/absolute/path/to/your/leetcode

# Retrieval + orchestration tuning.
RETRIEVAL_TOP_K=3
MAX_LOOPS=2
